# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — it will never be committed.

# Get a free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — defaults to gemini-3.1-flash-lite if unset (gemini-3.5-flash is
# frequently overloaded on the free tier as of writing).
# GEMINI_MODEL=gemini-3.1-flash-lite

# From your Supabase project: Settings -> Data API (Project URL + anon public key).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
